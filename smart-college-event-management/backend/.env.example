# Server
PORT=5001

# MongoDB — paste your Atlas or local connection string
MONGO_URI=mongodb://127.0.0.1:27017/smart-events
MONGO_RETRY_MS=10000

# Razorpay (https://dashboard.razorpay.com/app/keys)
# Use test keys while developing
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_CURRENCY=INR
RAZORPAY_MODE=test

# Optional: legacy Stripe (not used by EventHub UI)
STRIPE_SECRET_KEY=
